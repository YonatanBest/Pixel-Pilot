{
  "name": "pixelpilot-desktop",
  "private": true,
  "version": "0.2.0",
  "description": "PixelPilot desktop app",
  "author": "PixelPilot",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:runtime": "node scripts/build-runtime.mjs",
    "build:release-config": "node scripts/write-release-config.mjs",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main && node scripts/stage-runtime.mjs",
    "build:package": "npm run build:release-config && npm run build",
    "start": "node scripts/run-electron.mjs dist/main/index.js",
    "test": "vitest run",
    "package:msi": "npm run build:runtime && npm run build:package && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win msi",
    "package:win": "npm run package:msi"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.pixelpilot.desktop",
    "productName": "PixelPilot",
    "msiProjectCreated": "scripts/customize-msi-project.cjs",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "dist/**/*",
      "!dist/win-unpacked{,/**}",
      "!dist/__msi-x64{,/**}",
      "!dist/*.msi",
      "!**/.env",
      "!**/.env.*"
    ],
    "extraResources": [
      {
        "from": "resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../src/logos/pixelpilot-icon.ico",
        "to": "tray-icon.ico"
      },
      {
        "from": "resources/release-config.json",
        "to": "release-config.json"
      },
      {
        "from": "resources/installer",
        "to": "installer",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "../src/logos/pixelpilot-icon.ico",
      "target": [
        "msi"
      ]
    },
    "protocols": [
      {
        "name": "PixelPilot Deep Link",
        "schemes": [
          "pixelpilot"
        ]
      }
    ],
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "additionalWixArgs": [
        "-ext",
        "WixUtilExtension"
      ]
    }
  }
}