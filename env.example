# Direct mode (optional). Leave empty to use backend auth flow.
GEMINI_API_KEY=your_api_key_here

# Hosted backend and web endpoints for production/tester builds.
BACKEND_URL=https://your-backend-domain.onrender.com
WEB_URL=https://pixelpilotai.vercel.app

# Hosted backend required services.
MONGODB_URI=mongodb+srv://...
REDIS_URI=redis://localhost:6379
JWT_SECRET=replace_with_a_long_random_secret

# The live model
GEMINI_LIVE_MODEL="gemini-3.1-flash-live-preview" #gemini-2.5-flash-native-audio-preview-12-2025
LIVE_SESSION_SECONDS_PER_DAY=600
